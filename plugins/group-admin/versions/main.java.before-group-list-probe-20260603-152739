    try {
        delChatroomMember(groupId, wxid);
        setBotPriv(groupId, "admin");
        return true;
    } catch (Exception e) {
        if (isPermissionError(e)) setBotPriv(groupId, "none");
        log("kick fail group=" + groupId + " wxid=" + wxid + " err=" + e.getMessage());
        return false;
    }
}

