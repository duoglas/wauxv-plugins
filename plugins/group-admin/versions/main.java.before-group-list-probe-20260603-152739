// ========== 潜水追踪 ==========
// 存: lsg_<groupId> = wxid|ts,...  (last_speak), fsg_<groupId> = wxid|ts,... (first_seen)
void recordSpeak(String groupId, String wxid) {
    if (groupId == null || wxid == null || groupId.isEmpty() || wxid.isEmpty()) return;
    long now = System.currentTimeMillis();

    String lkey = "lsg_" + groupId;
    Map lm = parseTimeCsv(getString(lkey, ""));
    lm.put(wxid, Long.valueOf(now));
    putString(lkey, buildTimeCsv(lm));

    String fkey = "fsg_" + groupId;
    Map fm = parseTimeCsv(getString(fkey, ""));
    if (!fm.containsKey(wxid)) {
        fm.put(wxid, Long.valueOf(now));
        putString(fkey, buildTimeCsv(fm));
    }
}

void recordFirstSeen(String groupId, String wxid) {
    if (groupId == null || wxid == null) return;
    String fkey = "fsg_" + groupId;
    Map fm = parseTimeCsv(getString(fkey, ""));
    if (!fm.containsKey(wxid)) {
        fm.put(wxid, Long.valueOf(System.currentTimeMillis()));
        putString(fkey, buildTimeCsv(fm));
    }
}

// 把群里所有当前成员中没 first_seen 的人设为 now (建立基线)
// 返回新设置的人数
int initFirstSeenBaseline(String groupId) {
    if (groupId == null || groupId.isEmpty()) return 0;
    List members = null;
    try { members = getGroupMemberList(groupId); } catch (Exception e) { log("baseline: getGroupMemberList fail " + groupId + " " + e); }
    if (members == null || members.isEmpty()) return 0;
    String fkey = "fsg_" + groupId;
    Map fm = parseTimeCsv(getString(fkey, ""));
    long now = System.currentTimeMillis();
    int added = 0;
    for (int i = 0; i < members.size(); i++) {
        String w = (String) members.get(i);
        if (w == null || w.isEmpty()) continue;
        if (!fm.containsKey(w)) { fm.put(w, Long.valueOf(now)); added++; }
    }
    if (added > 0) putString(fkey, buildTimeCsv(fm));
    return added;
}

