            try { if (!v.isEmpty()) { putString(K_RULE_PREFIX, v); toast("✅ 群规前缀(原样发送): " + v); } else toast("❌ 格式: 红包群规前缀 领红包请遵守群规执行"); } catch (Throwable t) {}
