            try { if (!v.isEmpty()) { putString(K_TXT3, v); toast("✅ 档3动作核心词(原样, 周围措辞自动随机): " + v); } else toast("❌ 格式: 红包文案3 发视频"); } catch (Throwable t) {}
            return true;
        }
        // v1.0.7 §14: >上限通用群规消息前缀, 单值原样存储/发送 (不随机)。
        if (content.startsWith("红包群规前缀")) {
