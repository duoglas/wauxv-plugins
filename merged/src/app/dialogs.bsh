    final AlertDialog[] dh = new AlertDialog[1];

    android.widget.Button gaTgl = _gaBtn(ctx, gaG ? "🛡 群管全局: 开 → 点击关闭" : "🛡 群管全局: 关 → 点击开启", gaG ? "#FF6B6B" : "#5CB6FF");
    gaTgl.setOnClickListener(new android.view.View.OnClickListener() {
        public void onClick(android.view.View v) {
            setGaGlobal(!gaG);
            toast(!gaG ? "群管全局已开启" : "群管全局已关闭 (所有群群管停用)");
            if (dh[0] != null) dh[0].dismiss();
            showMergedHome();
        }
    });
    root.addView(gaTgl);
    _gaSpacer(root, ctx, 6 * dp);

    android.widget.Button rpTgl = _gaBtn(ctx, rpG ? "🧧 红包全局: 开 → 点击关闭" : "🧧 红包全局: 关 → 点击开启", rpG ? "#FF6B6B" : "#5CB6FF");
    rpTgl.setOnClickListener(new android.view.View.OnClickListener() {
        public void onClick(android.view.View v) {
            setRpGlobal(!rpG);
            toast(!rpG ? "红包全局已开启" : "红包全局已关闭 (所有群红包停用)");
            if (dh[0] != null) dh[0].dismiss();
            showMergedHome();
        }
    });
    root.addView(rpTgl);
    _gaSpacer(root, ctx, 14 * dp);

    android.widget.Button pickBtn = _gaBtn(ctx, "📂 选群配置 (群管 + 红包)", "#252934");
    pickBtn.setOnClickListener(new android.view.View.OnClickListener() {
        public void onClick(android.view.View v) {
