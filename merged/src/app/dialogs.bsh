    dh[0].show();
}

// ████████████████████████████████████████████████████████████████████████
// ████ RedPacketStats 设置 UI (P3-b 移植自线上 plugins/redpacket-stats/main.java) ████
// ████████████████████████████████████████████████████████████████████████
// 逐字保真移植自线上 §23 设置页拆分 (主菜单 Dialog + 7 子页 + UI/Forward/落库 helper)。
//   行为零改, 只换载体 (拼接式单文件 → 模块) + 按符号改名表替换:
//     getString(k,def)→HOST.getString  putString(k,v)→HOST.putString  sendText→HOST.sendText
//     tiersCustomKey→rpTiersCustomKey
//     K_T1/2/3→RP_K_T1/2/3  K_TXT1/2/3→RP_K_TXT1/2/3  K_DELAY→RP_K_DELAY  K_RETRY1/2/3→RP_K_RETRY1/2/3  (K_AT_LIMIT 保持)
//     K_FREELOADER_ON_PREFIX→RP_K_FREELOADER_ON_PREFIX  K_FREELOADER_WIN_PREFIX→RP_K_FREELOADER_WIN_PREFIX  (K_FREELOADER_SINCE_PREFIX 保持)
//     K_EXPORT_TARGET→RP_K_EXPORT_TARGET  K_EXPORT_TARGET_NAME→RP_K_EXPORT_TARGET_NAME  K_DAILY_HOUR→K_DAILY_HOUR_KEY
//     isGroupEnabled→rpIsGroupEnabled / enableGroup→rpEnableGroup / disableGroup→rpDisableGroup
//       (RP 本群开关读写, 合并里 RP 路径已独立命名以避与 GA 同名函数撞名; 键同源 RP_K_ENABLED, redpacket_detect.bsh)
//   ★C-PERF-01/03: 全部 Dialog/命令在 UI 线程, 绝不进 onHandleMsg 热路径; 取数/发送各自后台 Thread + try/catch。
//   ★不移植 onClickSendBtn (RP 线上 @1333, 与 GA 撞名, 留 T8 命令路由收口)。
//   getTopActivity/toast/delay/getFriendList/getGroupList/getFriendDisplayName/getRemark/getNickname/getRoomId/getName
//     = WAuxiliary 宿主注入 leaf (解析门只查语法, 不解析这些类型/符号)。sCachedFriendList/sCachedGroupList = device_base.bsh。
// ████████████████████████████████████████████████████████████████████████

// 目标是否为群 (线上 rpTargetIsGroup @905 逐字; UI 显示「（群）/（好友）」用)。
boolean rpTargetIsGroup(String target) { try { return target != null && target.indexOf("@chatroom") >= 0; } catch (Throwable t) { return false; } }

// ----- RP UI 基建 helper (线上 @3221-3271 逐字) -----
int _rpC(String s) { return android.graphics.Color.parseColor(s); }
android.graphics.drawable.GradientDrawable _rpRound(String fill, int radius) {
    android.graphics.drawable.GradientDrawable d = new android.graphics.drawable.GradientDrawable();
    d.setColor(_rpC(fill));
    d.setCornerRadius(radius);
    return d;
}
android.widget.Button _rpBtn(Activity ctx, String text, String fillColor) {
    int dp = (int) ctx.getResources().getDisplayMetrics().density;
    android.widget.Button b = new android.widget.Button(ctx);
    b.setText(text);
    b.setTextColor(_rpC("#E8E9EC"));
    b.setBackground(_rpRound(fillColor, 24));
    b.setAllCaps(false);
    b.setTextSize(14);
    b.setPadding(20 * dp, 12 * dp, 20 * dp, 12 * dp);
    b.setLayoutParams(new android.widget.LinearLayout.LayoutParams(
        android.widget.LinearLayout.LayoutParams.MATCH_PARENT,
        android.widget.LinearLayout.LayoutParams.WRAP_CONTENT));
    return b;
}
android.widget.EditText _rpEdit(Activity ctx, String val, boolean numeric) {
    int dp = (int) ctx.getResources().getDisplayMetrics().density;
    android.widget.EditText e = new android.widget.EditText(ctx);
    e.setText(val);
    e.setTextColor(_rpC("#E8E9EC"));
    e.setHintTextColor(_rpC("#7C828E"));
    e.setBackground(_rpRound("#252934", 12));
    e.setPadding(12 * dp, 8 * dp, 12 * dp, 8 * dp);
    e.setTextSize(14);
    if (numeric) e.setInputType(android.text.InputType.TYPE_CLASS_NUMBER);
    e.setLayoutParams(new android.widget.LinearLayout.LayoutParams(
        android.widget.LinearLayout.LayoutParams.MATCH_PARENT,
        android.widget.LinearLayout.LayoutParams.WRAP_CONTENT));
    return e;
}
void _rpLabel(android.widget.LinearLayout root, Activity ctx, String text) {
    int dp = (int) ctx.getResources().getDisplayMetrics().density;
    android.widget.TextView tv = new android.widget.TextView(ctx);
    tv.setText(text);
    tv.setTextColor(_rpC("#E8E9EC"));
    tv.setTextSize(13);
    tv.setPadding(0, 8 * dp, 0, 4 * dp);
    root.addView(tv);
}
void _rpSpacer(android.widget.LinearLayout root, Activity ctx, int h) {
    android.view.View v = new android.view.View(ctx);
    v.setLayoutParams(new android.widget.LinearLayout.LayoutParams(
        android.widget.LinearLayout.LayoutParams.MATCH_PARENT, h));
    root.addView(v);
}

// ================================================================
// ===== UI 重建 (2026-06-11): 群管 + 红包 设置合并 + 全局开关 顶层 =====
//   设计: 不重写两棵现有菜单树 (showGroupConfigDialog=GA / showConfigDialog=RP), 它们原样留作「功能子页」;
//         本节只加合并父页 (showMergedHome) + 选群 (pickGroupForConfig) + 合并群配置 (showMergedGroupConfig)。
//   全局开关 = 一票否决: setGaGlobal/setRpGlobal (enable_state.bsh / redpacket_detect.bsh), 空键=开 (升级安全)。
//   入口: openSettings (设置按钮) → showMergedHome; gaOnClickSendBtn「群管」→ showMergedGroupConfig(本群)。
//   UI helper 复用 GA 侧 (_gaBtn/_gaRound/_gaC/_gaSpacer); 选群复用 rpPickTarget 的群分支范式 (后台 getGroupList → 单选)。
// ================================================================

// ----- 顶层合并主页: 两个全局开关 + 选群入口 + 红包全局默认 -----
void showMergedHome() {
    Activity ctx = getTopActivity();
    if (ctx == null) { toast("无法获取 Activity"); return; }
    int dp = (int) ctx.getResources().getDisplayMetrics().density;

    android.widget.LinearLayout root = new android.widget.LinearLayout(ctx);
