    android.widget.Button addBtn = _gaBtn(ctx, "➕ 添加全局群主", "#5CB6FF");
    addBtn.setOnClickListener(new android.view.View.OnClickListener() {
        public void onClick(android.view.View v) {
            String w = inp.getText().toString().trim();
