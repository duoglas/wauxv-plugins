// ============================================================
// app/ai_recap — AI 群聊点评/锐评: 取 chat_recent 转录 + 排行榜摘要 → LLM 生成锐评 → 发本群。
// 设计源: docs/superpowers/specs/2026-06-11-排行榜-ranking-design.md (AI 点评增量)
// 依赖: domain/chat_recent.bsh(chatRecentQuery) + app/rank_render.bsh(_rankName/rankBuildBoard/_rankTodayStart) + app/llm.bsh(llmChat) + 全局 HOST。
//
// 红线: 出点评全后台线程(转录+LLM 不上消息热路径); 失败/无 key/消息太少 → 友好提示不卡; 转录/content 绝不写日志; key 不入源码。
//   风格 = 可配置 system prompt(键 ga_llm_recap_system, onLoad 可 seed); 默认机智吐槽(不人身攻击/不涉黄/不造谣)。
// ============================================================

String DEFAULT_RECAP_SYS = "你是这个群里一个嘴特别损但很懂梗的老群友, 随手写今天的『群聊锐评』发群里。别端着、别用力过猛。我给你今天本群的聊天记录(发言人: 内容)和排行榜数据。\n\n写作要求:\n① 开场别铺垫, 直接抛今天最好笑/最离谱的人和事。\n② 挑今天最精彩的四个人或事, 一个一个把来龙去脉讲清楚 —— 谁干了啥、前后怎么打脸/自相矛盾、怎么收场, 用记录里的真实原话(引号引出来), 越具体越好笑。是讲故事/讲段子, 不是罗列句子、也不是笼统概括。每个两三句讲完, 剩下的人别面面俱到。\n③ 排行榜数字编进吐槽里(谁话痨、谁水、谁红包), 别做成工整颁奖模板。\n④ 每个人换着花样写, 别一个句式套到底。结尾随手收, 别硬升华、别『总之/最大赢家』。\n\n避免 AI 味:\n- 句式参差、口语化, 像人随手打字, 别每句工整对仗、别每句硬凑金句; 有张有弛, 允许平淡的真实观察句。\n- 别滥用套路梗: 『主打一个X』『这不是X而是Y』『建议改名』『XX担当』『堪称』『活像』, 整篇偶尔一两个就顶天了。\n- 别按时间顺序干巴巴一句句复述, 要有你自己的观察、态度、和好笑的落点。\n\n准确(底线): 每件事都得对得上记录里那个人的真实原话, 别把 A 说的安到 B 头上, 别编, 拿不准是谁说的就别写。\n\n红线: 可以辣可以损可以阴阳, 但不人身攻击/不涉黄赌毒/不地域歧视/不造谣。整篇别超过 700 字, 宁可少写一个人也别拖长。只输出锐评正文, 不要标题/前后缀。";

String recapSystemPrompt() {
    try { String s = HOST.getString("ga_llm_recap_system", "").trim(); if (s.length() > 0) return s; } catch (Throwable t) {}
    return DEFAULT_RECAP_SYS;
}

boolean recapHasKey() {
    try { return HOST.getString("ga_llm_key", "").trim().length() > 0; } catch (Throwable t) { return false; }
}

// 构建喂 LLM 的 user prompt: 转录(最近≤300条, 字符预算≤6000) + 排行榜摘要。消息太少(<5)返 null。
String recapBuildPrompt(String groupId, long sinceTs, long untilTs) {
    java.util.List rows = chatRecentQuery(groupId, sinceTs, untilTs, 300);
    if (rows == null || rows.size() < 5) return null;   // 消息太少不点评
    StringBuilder sb = new StringBuilder();
    sb.append("【今日群聊记录】(发言人: 内容)\n");
    int budget = 6000;
    for (int i = 0; i < rows.size(); i++) {
        Object[] r = (Object[]) rows.get(i);
        String nm = _rankName((String) r[0], groupId);
        // 内容里的换行压成空格: 保证『一条消息一行、说话人永远带前缀』, 防止多行消息的后续行被模型算到错的人头上(张冠李戴根因之一)。
        String c = (r[2] == null) ? "" : r[2].toString();
        c = c.replace("\r", " ").replace("\n", " ").trim();
        String line = nm + ": " + c + "\n";
        if (sb.length() + line.length() > budget) break;
        sb.append(line);
    }
    try {
        String board = rankBuildBoard(groupId, sinceTs, untilTs);
        if (board != null) sb.append("\n【排行榜数据】\n").append(board);
    } catch (Throwable t) {}
    return sb.toString();
}

// 生成锐评文本(可测: 桩 llmChat)。无转录/LLM 失败 → null。
String aiRecapText(String groupId, long sinceTs, long untilTs) {
    String prompt = recapBuildPrompt(groupId, sinceTs, untilTs);
    if (prompt == null) return null;
    return llmChat(recapSystemPrompt(), prompt, 0.85);   // 讲故事型: temp≈0.85 有梗有态度又不至于堆烂比喻(实验台验证)
}

// 命令入口: 后台线程生成 + 发本群。
void aiRecapShow(String groupId, String content) {
    try {
        new Thread(new Runnable() {
            public void run() {
                try {
                    // 群聊可见文案不暴露 LLM/大模型/采集机制(用户反馈 2026-06-14); 命令路径出错只给最小提示, 配置细节在设置页。
                    if (!recapHasKey()) { try { HOST.sendText(groupId, "🤖 点评功能尚未配置好 (管理员请到设置里完成)"); } catch (Throwable t) {} return; }
                    String txt = aiRecapText(groupId, _rankTodayStart(), Long.MAX_VALUE);
                    if (txt == null || txt.trim().length() == 0) {
                        try { HOST.sendText(groupId, "📝 今日消息太少, 暂时生成不了"); } catch (Throwable t) {}
                        return;
                    }
                    HOST.sendText(groupId, txt);
                } catch (Throwable t) {
                    try { HOST.sendText(groupId, "📝 生成出错, 请稍后再试"); } catch (Throwable t2) {}
                }
            }
        }).start();
    } catch (Throwable t) {}
}
