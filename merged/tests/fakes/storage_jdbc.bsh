// JDBC StoragePort（集成测试用）：sqlite-jdbc 真库执行同一份 SQL。
// 与生产 android 适配器同契约(exec/queryLong)，SQL 完全相同 → 本机验真 SQL 语义。
import java.sql.*;

Object makeJdbcStorage(Connection conn) {
    void _bind(PreparedStatement ps, Object[] binds) {
        for (int i = 0; i < binds.length; i++) {
            Object b = binds[i];
            if (b instanceof Long) ps.setLong(i + 1, ((Long) b).longValue());
            else if (b == null) ps.setObject(i + 1, null);
            else ps.setString(i + 1, b.toString());
        }
    }
    void exec(String sql, Object[] binds) {
        PreparedStatement ps = conn.prepareStatement(sql);
        _bind(ps, binds);
        ps.executeUpdate();
        ps.close();
    }
    Long queryLong(String sql, Object[] binds) {
        PreparedStatement ps = conn.prepareStatement(sql);
        _bind(ps, binds);
        ResultSet rs = ps.executeQuery();
        Long out = null;
        if (rs.next()) { long v = rs.getLong(1); if (!rs.wasNull()) out = new Long(v); }
        rs.close(); ps.close();
        return out;
    }
    return this;
}

// 便捷：建内存库 + 接好 STORAGE。
Connection jdbcMemoryConn() {
    Class.forName("org.sqlite.JDBC");
    return DriverManager.getConnection("jdbc:sqlite::memory:");
}
