// L2 集成: domain/rank 聚合榜 + sqlite-jdbc 真库 —— 验真 SQL(窗口/GROUP BY/ORDER BY/LIMIT/coalesce/排除机器人/type 计数)。
// 运行 cwd = merged/, classpath 含 sqlite-jdbc.jar。
import java.sql.*;
source("tests/_harness.bsh");
source("src/domain/rank.bsh");
source("tests/fakes/storage_jdbc.bsh");

Connection conn = jdbcMemoryConn();
conn.createStatement().execute(RANK_CREATE_SQL);
conn.createStatement().execute(RANK_INDEX_SQL);
STORAGE = makeJdbcStorage(conn);

String G = "gA@chatroom";
String G2 = "gB@chatroom";
long T = 1749470000000L;
long SINCE = T;
long UNTIL = T + 1000L;

// 群A: wxA 3 文本(2/3/10), wxB 1 文本(100)+1 非文本(null), bot 5 文本(应被排除)
rankInsertEvent(G, "wxA", RANK_TYPE_TEXT, T + 1, new Long(2L));
rankInsertEvent(G, "wxA", RANK_TYPE_TEXT, T + 2, new Long(3L));
rankInsertEvent(G, "wxA", RANK_TYPE_TEXT, T + 3, new Long(10L));
rankInsertEvent(G, "wxB", RANK_TYPE_TEXT, T + 4, new Long(100L));
rankInsertEvent(G, "wxB", RANK_TYPE_OTHER, T + 5, null);
for (int i = 0; i < 5; i++) rankInsertEvent(G, "botwx", RANK_TYPE_TEXT, T + 6 + i, new Long(999L));
rankInsertEvent(G2, "wxC", RANK_TYPE_TEXT, T + 6, new Long(7L));
rankInsertEvent(G, "wxA", RANK_TYPE_TEXT, T - 100000L, new Long(50L));   // 窗口外

// ---- 话痨榜 + 排除机器人: bot 发 5 条但被排除, wxA=3 第一, wxB=2 ----
java.util.List cnt = rankTopNCount(G, SINCE, UNTIL, "botwx", 10);
check("排除机器人后 2 人(bot 不进榜)", cnt.size() == 2);
Object[] c0 = (Object[]) cnt.get(0);
check("话痨第一 = wxA (3 条)", "wxA".equals(c0[0]) && ((Long) c0[1]).longValue() == 3L);
check("榜内无 botwx", !"botwx".equals(c0[0]) && !"botwx".equals(((Object[]) cnt.get(1))[0]));
// 不排除时 bot(5条)应居首
java.util.List cntAll = rankTopNCount(G, SINCE, UNTIL, "", 10);
check("不排除(\"\")时 bot 5 条居首", "botwx".equals(((Object[]) cntAll.get(0))[0]));

// ---- 水王(字数 SUM, 排除 bot): wxB=100 第一, wxA=15 ----
java.util.List sum = rankTopNSum(G, RANK_TYPE_TEXT, SINCE, UNTIL, "botwx", 10);
Object[] s0 = (Object[]) sum.get(0);
check("水王第一 = wxB(100字)", "wxB".equals(s0[0]) && ((Long) s0[1]).longValue() == 100L);
check("水王 bot 被排除", sum.size() == 2);

// ---- 图王(type=OTHER 计数): 仅 wxB 1 张 ----
java.util.List pic = rankTopNCountType(G, RANK_TYPE_OTHER, SINCE, UNTIL, "botwx", 10);
check("图王榜 1 人(wxB)", pic.size() == 1);
check("图王 = wxB 1 张", "wxB".equals(((Object[]) pic.get(0))[0]) && ((Long) ((Object[]) pic.get(0))[1]).longValue() == 1L);

// ---- LIMIT / 空窗口 / coalesce NULL ----
check("LIMIT 1 → 1 行", rankTopNCount(G, SINCE, UNTIL, "botwx", 1).size() == 1);
check("空窗口 → 空", rankTopNCount(G, T + 5000L, T + 6000L, "botwx", 10).isEmpty());
java.util.List sumOther = rankTopNSum(G, RANK_TYPE_OTHER, SINCE, UNTIL, "botwx", 10);
check("全 NULL val SUM coalesce → 0", ((Long) ((Object[]) sumOther.get(0))[1]).longValue() == 0L);

// ---- 概览 rankSummary: 排除 bot, 窗口内 发言人数=2(wxA,wxB) 总消息=5(wxA3+wxB2) ----
java.util.List sm = rankSummary(G, SINCE, UNTIL, "botwx");
Object[] smr = (Object[]) sm.get(0);
check("概览 发言人数(distinct)=2", ((Long) smr[0]).longValue() == 2L);
check("概览 总消息=5 (排除 bot, 窗口内)", ((Long) smr[1]).longValue() == 5L);
check("概览 不排除时 总消息=10 (含 bot 5)", ((Long) ((Object[]) rankSummary(G, SINCE, UNTIL, "").get(0))[1]).longValue() == 10L);

conn.close();
done();
