// L2 集成：redpacket_store 领域 + sqlite-jdbc 真库（验真 SQL 语义 = 表/列/WHERE/ORDER BY 逐字保真）。
// 建表 → 录入多条(多群/达标边界/INSERT OR REPLACE 幂等) → 查当日 + 按群聚合 → 断言计数/合计/分组/排序。
// 含边界: 跨天 date WHERE 过滤、空结果、qualified_count 求和。
// 运行 cwd = merged/，classpath 含 sqlite-jdbc.jar。
import java.sql.*;
source("tests/_harness.bsh");
source("src/domain/redpacket_store.bsh");
source("tests/fakes/storage_jdbc.bsh");

Connection conn = jdbcMemoryConn();
conn.createStatement().execute(RP_CREATE_SQL);
STORAGE = makeJdbcStorage(conn);

String TODAY = "2026-06-09";
String YDAY = "2026-06-08";
long T = 1749470000000L;

// ---- 录入: gA 两个红包(达标 2 人 + 3 人), gB 一个红包(达标 1 人), 昨天 gA 一个(不应进当日) ----
rpRecord("k1", TODAY, T + 100, "gA@chatroom", "群A", "wx_s1", "张三", "拼手气", 2L, "李四|6|1;王五|8|2");
rpRecord("k2", TODAY, T + 300, "gA@chatroom", "群A", "wx_s2", "李四", "新年快乐", 3L, "a|5|1;b|7|1;c|9|2");
rpRecord("k3", TODAY, T + 200, "gB@chatroom", "群B", "wx_s3", "王五", "", 1L, "d|6|1");
rpRecord("kY", YDAY,  T - 99999999L, "gA@chatroom", "群A", "wx_s9", "昨天", "旧包", 1L, "x|6|1");

// ---- 查当日: 应只 3 行(昨天的被 date WHERE 过滤), 且 ORDER BY grp ASC, ts ASC ----
java.util.List rows = rpQueryToday(TODAY);
check("当日查询行数 = 3 (date WHERE 过滤掉昨天)", rows.size() == 3);

// 排序: gA(ts+100) , gA(ts+300) , gB(ts+200) —— grp 升序优先, 群内 ts 升序。
Object[] r0 = (Object[]) rows.get(0);
Object[] r1 = (Object[]) rows.get(1);
Object[] r2 = (Object[]) rows.get(2);
check("行0 grp=gA (grp 升序)", "gA@chatroom".equals(r0[6]));
check("行1 grp=gA", "gA@chatroom".equals(r1[6]));
check("行2 grp=gB (grp 升序在后)", "gB@chatroom".equals(r2[6]));
check("群内 ts 升序: 行0.ts < 行1.ts", ((Long) r0[0]).longValue() < ((Long) r1[0]).longValue());

// 列映射保真: [1]=sender_name [2]=title [3]=qualified_count [4]=qualifiers [5]=group_name [6]=grp
check("行0 sender_name = 张三", "张三".equals(r0[1]));
check("行0 title = 拼手气", "拼手气".equals(r0[2]));
check("行0 qualified_count = 2", ((Long) r0[3]).longValue() == 2L);
check("行0 qualifiers 串保真", "李四|6|1;王五|8|2".equals(r0[4]));
check("行0 group_name = 群A", "群A".equals(r0[5]));
check("行2 title 空串保真", "".equals(r2[2]));

// ---- 按群聚合: gA 2 个红包/达标 5 人; gB 1 个红包/达标 1 人; 按 grp 升序 ----
java.util.List agg = rpAggregateTodayByGroup(TODAY);
check("聚合分 2 群", agg.size() == 2);
Object[] aA = (Object[]) agg.get(0);
Object[] aB = (Object[]) agg.get(1);
check("聚合[0] grp = gA (grp 升序)", "gA@chatroom".equals(aA[0]));
check("聚合[0] groupName = 群A", "群A".equals(aA[1]));
check("聚合[0] 红包条数 count = 2", ((Long) aA[2]).longValue() == 2L);
check("聚合[0] 达标人数 sum = 5 (2+3)", ((Long) aA[3]).longValue() == 5L);
check("聚合[1] grp = gB", "gB@chatroom".equals(aB[0]));
check("聚合[1] count = 1", ((Long) aB[2]).longValue() == 1L);
check("聚合[1] sum = 1", ((Long) aB[3]).longValue() == 1L);

// ---- INSERT OR REPLACE 幂等: 同 key 重录(重试场景) → 覆盖而非新增, 当日仍 3 行 ----
rpRecord("k1", TODAY, T + 100, "gA@chatroom", "群A", "wx_s1", "张三改", "拼手气", 2L, "李四|6|1;王五|8|2");
java.util.List rows2 = rpQueryToday(TODAY);
check("INSERT OR REPLACE 同 key 幂等: 当日仍 3 行 (覆盖非新增)", rows2.size() == 3);
check("同 key 覆盖: sender_name 更新为 张三改", "张三改".equals(((Object[]) rows2.get(0))[1]));

// ---- 边界: 空结果(无该日记录) ----
java.util.List none = rpQueryToday("1999-01-01");
check("空日查询返回空列表", none.isEmpty());
java.util.List noneAgg = rpAggregateTodayByGroup("1999-01-01");
check("空日聚合返回空列表", noneAgg.isEmpty());

// ---- 边界: group_name 空 → 聚合 groupName 回退 grp (对齐线上头行取首条 group_name 空回退 grp) ----
rpRecord("k4", TODAY, T + 400, "gC@chatroom", "", "wx_s4", "赵六", "无群名", 1L, "e|6|1");
java.util.List agg2 = rpAggregateTodayByGroup(TODAY);
Object[] aC = null;
for (int i = 0; i < agg2.size(); i++) { Object[] x = (Object[]) agg2.get(i); if ("gC@chatroom".equals(x[0])) aC = x; }
check("gC 聚合存在", aC != null);
check("group_name 空 → groupName 回退 grp", "gC@chatroom".equals(aC[1]));

conn.close();
done();
